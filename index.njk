---
title: Cours
---
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Cours</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    .card-img-top {
      height: 180px;
      object-fit: cover;
      background: #f8f9fa;
    }
    .card-img-placeholder {
      height: 180px;
      background: #f0f0f0;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #adb5bd;
      font-size: 0.85rem;
    }
  </style>
</head>
<body class="bg-light">
<div class="container py-5">
  <div class="d-flex justify-content-between align-items-center mb-5">
    <h1 class="mb-0">Cours</h1>
    <a href="about.html" class="text-muted text-decoration-none fs-4" title="À propos">ⓘ</a>
  </div>
  <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
    {% for project in projects %}
    <div class="col">
      <div class="card h-100 shadow-sm">
        {% if project.screenshot %}
        <img src="screenshots/{{ project.screenshot }}" alt="{{ project.name }}" class="card-img-top">
        {% else %}
        <div class="card-img-placeholder">pas encore de capture</div>
        {% endif %}
        <div class="card-body">
          <h5 class="card-title">{{ project.name }}</h5>
          <p class="card-text text-muted">{{ project.description }}</p>
        </div>
        <div class="card-footer bg-transparent border-top-0 d-flex gap-2">
          {% if project.site %}
          <a href="{{ project.site }}" class="btn btn-sm btn-primary" target="_blank">Site</a>
          {% endif %}
          <a href="{{ project.repo }}" class="btn btn-sm btn-outline-secondary" target="_blank">GitHub</a>
        </div>
      </div>
    </div>
    {% endfor %}
  </div>
</div>
</body>
</html>
