---
title: Cours
---
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Cours</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    .card-img-top {
      height: 180px;
      object-fit: cover;
      background: #f8f9fa;
      border-top: 1px solid rgba(0,0,0,.1);
      border-bottom: 1px solid rgba(0,0,0,.1);
    }
    .card-img-placeholder {
      height: 180px;
      background: #f0f0f0;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #adb5bd;
      font-size: 0.85rem;
    }
  </style>
</head>
<body class="bg-light">
<div class="container py-5">
  <div class="d-flex justify-content-between align-items-center mb-5">
    <h1 class="mb-0">Cours</h1>
    <a href="about.html" class="text-muted text-decoration-none fs-4" title="À propos">ⓘ</a>
  </div>
  <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
    {% for project in projects %}
    <div class="col">
      <div class="card h-100 shadow-sm">
        <div class="card-body flex-grow-0">
          <h5 class="card-title mb-0">
            <a href="{{ project.site }}" class="text-decoration-none text-dark" target="_blank">{{ project.name }}</a>
          </h5>
        </div>
        <div class="px-3">
          <a href="{{ project.site }}" target="_blank" tabindex="-1">
            <img src="{{ project.screenshot }}" alt="{{ project.name }}" class="card-img-top w-100" style="border-radius: 4px;"
                 onerror="this.closest('a').style.display='none'; this.closest('a').nextElementSibling.style.display='flex'">
          </a>
          <div class="card-img-placeholder" style="display:none; border-radius: 4px;">pas encore de capture</div>
        </div>
        <div class="card-body flex-grow-1">
          <p class="card-text text-muted small">{{ project.description }}</p>
        </div>
        {% if project.topics.length %}
        <div class="card-body flex-grow-0 pt-0">
          <div class="d-flex flex-wrap gap-1">
            {% for topic in project.topics %}
            <span class="badge rounded-pill text-bg-light border">{{ topic }}</span>
            {% endfor %}
          </div>
        </div>
        {% endif %}
        <div class="card-footer bg-transparent border-top-0 d-flex align-items-center gap-2">
          {% if project.site %}
          <a href="{{ project.site }}" class="btn btn-sm btn-primary" target="_blank">Site</a>
          {% endif %}
          <a href="{{ project.repo }}" class="btn btn-sm btn-outline-secondary" target="_blank">GitHub</a>
          <time class="ms-auto small" style="color: #adb5bd;" data-ts="{{ project.updated }}"></time>
        </div>
      </div>
    </div>
    {% endfor %}
  </div>
</div>
<script>
function relativeTime(dateStr) {
  const seconds = Math.floor((Date.now() - new Date(dateStr)) / 1000);
  if (seconds < 60) return "à l'instant";
  const minutes = Math.floor(seconds / 60);
  if (minutes < 60) return `il y a ${minutes} minute${minutes > 1 ? 's' : ''}`;
  const hours = Math.floor(minutes / 60);
  if (hours < 24) return `il y a ${hours} heure${hours > 1 ? 's' : ''}`;
  const days = Math.floor(hours / 24);
  if (days < 7) return `il y a ${days} jour${days > 1 ? 's' : ''}`;
  const weeks = Math.floor(days / 7);
  if (weeks < 5) return `il y a ${weeks} semaine${weeks > 1 ? 's' : ''}`;
  const months = Math.floor(days / 30);
  if (months < 12) return `il y a ${months} mois`;
  const years = Math.floor(days / 365);
  return `il y a ${years} an${years > 1 ? 's' : ''}`;
}
document.querySelectorAll('time[data-ts]').forEach(el => {
  el.textContent = 'modifié ' + relativeTime(el.dataset.ts);
});
</script>
</body>
</html>
